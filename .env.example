# ===================================
# Portalyx Environment Configuration
# ===================================

# ===================================
# Application Settings
# ===================================
APP_NAME=Portalyx
APP_ENV=development
APP_DEBUG=true

# ===================================
# Flask Configuration
# ===================================
FLASK_ENV=development
FLASK_APP=src/portalyx_app.py
FLASK_DEBUG=1
SECRET_KEY=your-super-secret-key-change-this-in-production

# ===================================
# Database Configuration (MariaDB/MySQL)
# ===================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_database_password
DB_NAME=portalyx_db
DB_CHARSET=utf8mb4
DB_DRIVER=mysql+pymysql

# ===================================
# JWT Authentication Settings
# ===================================
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ===================================
# API Server Configuration
# ===================================
API_HOST=0.0.0.0
API_PORT=5555
API_DEBUG=true
API_TESTING=false

# ===================================
# CORS Settings (Cross-Origin Resource Sharing)
# ===================================
CORS_ENABLED=true
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# ===================================
# Logging Configuration
# ===================================
LOG_LEVEL=INFO
LOG_FILE=logs/portalyx.log
LOG_MAX_SIZE=10MB
LOG_BACKUP_COUNT=5

# ===================================
# Email Configuration (for notifications)
# ===================================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-email-password
MAIL_FROM_ADDRESS=noreply@portalyx.com
MAIL_FROM_NAME=Portalyx Portal

# ===================================
# File Upload Configuration
# ===================================
MAX_UPLOAD_SIZE=5242880
UPLOAD_FOLDER=uploads/
ALLOWED_EXTENSIONS=pdf,txt,doc,docx,jpg,jpeg,png,xlsx,xls

# ===================================
# Session Configuration
# ===================================
SESSION_TIMEOUT=3600
SESSION_SECURE=false
SESSION_HTTPONLY=true
SESSION_SAMESITE=Lax

# ===================================
# Security Settings
# ===================================
BCRYPT_LOG_ROUNDS=12
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true

# ===================================
# Frontend Configuration
# ===================================
FRONTEND_URL=http://localhost:3000
FRONTEND_API_BASEURL=http://localhost:5555/api

# ===================================
# Third-party Services (Optional)
# ===================================
# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ===================================
# Admin Configuration
# ===================================
ADMIN_EMAIL=admin@portalyx.com
ADMIN_PASSWORD=admin-default-password
ADMIN_FIRST_NAME=Portal
ADMIN_LAST_NAME=Admin

# ===================================
# Feature Flags
# ===================================
FEATURE_STUDENT_PORTAL=true
FEATURE_FACULTY_GRADING=true
FEATURE_REGISTRAR_ENROLLMENT=true
FEATURE_ADMIN_DASHBOARD=true
FEATURE_EMAIL_NOTIFICATIONS=false

# ===================================
# Development Tools (Development Only)
# ===================================
SQLALCHEMY_ECHO=false
SQLALCHEMY_TRACK_MODIFICATIONS=false

# ===================================
# Timezone
# ===================================
TIMEZONE=UTC

# ===================================
# Redis Cache (Optional)
# ===================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0